# Archivo de ejemplo de variables de entorno
# Copiar como .env y ajustar valores

# MQTT Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=scada_user
MQTT_PASSWORD=cambiar_esta_contraseña
MQTT_CLIENT_ID=raspberry_gateway_01

# Serial Configuration
SERIAL_PORT=/dev/ttyACM0
SERIAL_BAUDRATE=115200

# Database Configuration
DATABASE_PATH=./data/scada_local.db
DATABASE_RETENTION_DAYS=7

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/gateway.log

# Diagnostics
DIAGNOSTICS_ENABLED=true
DIAGNOSTICS_CHECK_INTERVAL=60
DIAGNOSTICS_PUBLISH_INTERVAL=300

# Thresholds
TEMP_WARNING=70
TEMP_CRITICAL=80
CPU_WARNING=80
CPU_CRITICAL=95
MEMORY_WARNING=85
MEMORY_CRITICAL=95

# Planta Configuration
PLANTA_ID=planta1
PLANTA_NOMBRE=Planta de Mezclas - Prototipo IC1
